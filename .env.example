# Copy this file to `.env` and fill in the values.
# `.env` is git-ignored: it holds the secrets and never leaves your machine.
# In production, Vercel provides these as environment variables.

# --- Site ---------------------------------------------------------------
# Public settings, safe to expose to the browser.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_DISQUS_SHORTNAME="genomagames"
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""
NEXT_PUBLIC_POSTS_PER_PAGE="10"
NEXT_PUBLIC_SHOW_DRAFTS="true"
NEXT_PUBLIC_SITE_NAME="Genoma Games"
NEXT_PUBLIC_SITE_DESCRIPTION="Indie Game Development Studio located in Madrid, Spain"
NEXT_PUBLIC_X_USERNAME="GenomaGames"
NEXT_PUBLIC_X_SHARE_POST_HASHTAGS="#gamedev"

# Editor opened when clicking a stack frame in the Next.js error overlay.
REACT_EDITOR=code

# --- Supabase -----------------------------------------------------------
# The database behind the website. The server is its only writer: Row Level
# Security denies every request that does not carry the secret key, so the
# secret key must never reach the browser.
#
# Where to find them: Supabase dashboard -> project "Genoma Games Web" ->
# Project Settings -> API Keys. The secret key is shown once, on creation.
# In production, both are injected by the Supabase integration in Vercel.
SUPABASE_URL="https://oglopzrrpsofndqmjxtk.supabase.co"
SUPABASE_SECRET_KEY=""

# --- Brevo --------------------------------------------------------------
# Sends the double opt-in confirmation email and calls back with the result.
#
# API key: Brevo dashboard -> SMTP & API -> API Keys.
# Webhook secret: chosen by us, and set on the webhook in Brevo. The endpoint
# rejects any callback that does not carry it, so nobody can forge a
# verification.
BREVO_API_KEY=""
BREVO_WEBHOOK_SECRET=""
